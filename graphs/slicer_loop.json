{
  "meta": {
    "title": "Slicer Loop Chopper",
    "description": "ChordProgression triggers Slicer slices in loop mode, chopping a piano loop into 16 segments.",
    "tags": ["slicer", "loop", "chopping", "beat-slicing"],
    "difficulty": "beginner",
    "domains": ["audio"]
  },
  "nodes": {
    "clock1": { "type": "Clock", "params": { "bpm": 120.0 } },
    "cp1": { "type": "ChordProgression", "params": {
      "steps": 4,
      "key_root": 0, "mode": 0, "octave": 2,
      "beats_per_step": 2, "gate_length": 0.8, "velocity": 0.9,
      "degree_0": 0, "voicing_0": 0, "ext_0": 0,
      "degree_1": 1, "voicing_1": 0, "ext_1": 0,
      "degree_2": 2, "voicing_2": 0, "ext_2": 0,
      "degree_3": 3, "voicing_3": 0, "ext_3": 0
    }},
    "slicer1": { "type": "Slicer", "params": {
      "file": "../assets/audio/836863__josefpres__piano-loops-197-octave-short-loop-120-bpm.wav",
      "slices": 16,
      "mode": 1,
      "volume": 0.8
    }},
    "out1": { "type": "audio_out", "params": {} }
  },
  "connections": [
    { "from": "clock1/beat_phase", "to": "cp1/beat_phase" },
    { "from": "cp1/notes",      "to": "slicer1/notes" },
    { "from": "cp1/gates",      "to": "slicer1/gates" },
    { "from": "cp1/velocities", "to": "slicer1/velocities" },
    { "from": "slicer1/output", "to": "out1/input" }
  ]
}
