{
  "meta": {
    "title": "SP404 Drum Sequencer",
    "description": "DrumSequencer triggers SP404 pads with per-track MIDI note mapping for drum and percussion samples.",
    "tags": ["sampler", "sp404", "drums", "sequencer"],
    "difficulty": "beginner",
    "domains": ["audio"]
  },
  "nodes": {
    "clock1": { "type": "Clock", "params": { "bpm": 95.0 } },
    "ds1": { "type": "DrumSequencer", "params": {
      "steps": 16,
      "kick_note": 36, "snare_note": 38, "hat_note": 40,
      "oh_note": 41, "clap_note": 42, "tom_note": 43,
      "kick_0": 1, "kick_4": 1, "kick_10": 1,
      "snare_4": 1, "snare_12": 1,
      "hat_0": 1, "hat_2": 1, "hat_4": 1, "hat_6": 1,
      "hat_8": 1, "hat_10": 1, "hat_12": 1, "hat_14": 1,
      "oh_6": 1
    }},
    "sp1": { "type": "SP404", "params": {
      "file": "../assets/sample_packs/sp404-kit/sp404-kit.json",
      "mode": 0,
      "volume": 0.8
    }},
    "out1": { "type": "audio_out", "params": {} }
  },
  "connections": [
    { "from": "clock1/bar_phase", "to": "ds1/phase" },
    { "from": "ds1/gates",      "to": "sp1/gates" },
    { "from": "ds1/notes",      "to": "sp1/notes" },
    { "from": "ds1/velocities", "to": "sp1/velocities" },
    { "from": "sp1/output", "to": "out1/input" }
  ]
}
